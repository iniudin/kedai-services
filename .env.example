# Copy to `.env` and adjust values.

# Used by Docker Compose for the Postgres container (see README).
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=kedai_pos
DATABASE_PORT=5432

# App listens on this port (host) when using Docker Compose; also used by `bun run dev`.
PORT=3000

# For local `bun run dev`, point at Postgres on your machine (localhost + DATABASE_PORT above).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kedai_pos
